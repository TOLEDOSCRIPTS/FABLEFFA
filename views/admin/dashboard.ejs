<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/path/to/your/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>Admin Dashboard</h2>
        <nav>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Users</a></li>
                <li><a href="#">Settings</a></li>
                <li><a href="#">Logs</a></li>
            </ul>
        </nav>
    </div>
    <div class="main-content">
        <header>
            <h1>Dashboard</h1>
        </header>
        <section class="stats">
            <div class="stat-card">
                <h3>Credits Count</h3>
                <p>1000</p>
            </div>
            <div class="stat-card">
                <h3>Admin Users Count</h3>
                <p>10</p>
            </div>
            <div class="stat-card">
                <h3>Theme Color</h3>
                <p>Blue</p>
            </div>
            <div class="stat-card">
                <h3>Server Status</h3>
                <p>Running</p>
            </div>
        </section>
        <section class="quick-actions">
            <h2>Quick Actions</h2>
            <button onclick="location.href='#'">Add User</button>
            <button onclick="location.href='#'">Manage Credits</button>
            <button onclick="location.href='#'">View Logs</button>
        </section>
    </div>
</body>
</html>